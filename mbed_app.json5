{
  "config": {
    // Controls MCU same-tick PRU_READ behavior (MBED_CONF_APP_SAME_TICK_MODE)
    "same-tick-mode": 1
  },
  "target_overrides": {
    "LPC1768": {
      "target.application-profile": "bare-metal",
      "target.memory_bank_config": {
        "IROM1": {
          // the first 16kB of ROM are taken by the bootloader code,
          // and the bootloader flashes the firmware starting at 16kB/0x4000
          "start": 0x4000,
          "size": 0x7c000,
        }
      },
      "target.c_lib": "std",
      "platform.stdio-baud-rate": 115200,
      // console routed to UART2 by code (mbed_override_console); keep baud here

    }
  }
}