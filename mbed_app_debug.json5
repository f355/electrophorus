{
  "target_overrides": {
    "LPC1768": {
      "target.application-profile": "bare-metal",
      "target.memory_bank_config": {
        "IROM1": {
          // the first 16kB of ROM are taken by the bootloader code,
          // and the bootloader flashes the firmware starting at 16kB/0x4000
          "start": 0x4000,
          "size": 0x7c000,
        }
      },
      "target.c_lib": "std",
      "target.boot-stack-size": 8192,
      "platform.stdio-baud-rate": 115200,
      "platform.crash-capture-enabled": false,
      "platform.error-hist-enabled": true,
      "platform.error-hist-size": 4,
      "platform.fatal-error-auto-reboot-enabled": false,
      "platform.error-reboot-max": 1,
      "platform.heap-stats-enabled": true,
      "platform.error-filename-capture-enabled": true,
      "platform.max-error-filename-len": 32,
    }
  }
}
